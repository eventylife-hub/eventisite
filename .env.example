# ===================== BASE =====================
NODE_ENV=development
PORT=4000

# ===================== DATABASE =====================
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/eventy_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eventy_dev
POSTGRES_PORT=5432

# ===================== AUTH =====================
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-here
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===================== STRIPE =====================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================== SENTRY =====================
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_RELEASE=unknown
SENTRY_ENVIRONMENT=development

# ===================== EMAIL =====================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_API_KEY=xkeysib_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@eventy.life

# ===================== STORAGE =====================
AWS_BUCKET=eventy-uploads
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================== FRONTEND =====================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_S3_BUCKET=eventy-uploads
NEXT_PUBLIC_S3_REGION=eu-west-1

# ===================== MONITORING =====================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxxxxxxxx

# ===================== MAPS & SERVICES =====================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================== SWAGGER & DEBUG =====================
SWAGGER_ENABLED=true
DEBUG=false
SEED_ON_START=false
REQUEST_TIMEOUT=30000

# ===================== DOCKER =====================
# Services Docker Compose
DOCKER_COMPOSE_PROJECT=eventy
DOCKER_NETWORK=eventy-network
